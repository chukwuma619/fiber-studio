{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fiber Studio",
  "version": "0.1.2",
  "identifier": "com.ebube.fiber-studio",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Fiber Studio",
        "width": 1024,
        "height": 768
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJEQTMxNjNBRUQzM0FCNEYKUldSUHF6UHRPaGFqTGFQNCtpekxvT1JSakc0cWpmMWJETStOY29ZV3dkSE03ZUlRU2owOUR3a0kK",
      "endpoints": [
        "https://github.com/chukwuma619/fiber-studio/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "shortDescription": "Run the Fiber Network node (fnn) on your machine",
    "publisher": "Fiber Studio",
    "category": "Utility",
    "externalBin": ["binaries/fnn"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libjavascriptcoregtk-4.1-0",
          "libsoup-3.0-0",
          "librsvg2-2",
          "libssl3"
        ]
      },
      "rpm": {
        "depends": [
          "webkit2gtk4.1",
          "gtk3",
          "librsvg2",
          "openssl-libs"
        ]
      }
    }
  }
}
